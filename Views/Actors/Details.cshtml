@model cprestegard_sp2026_assignment3.ViewModels.ActorDetailsViewModel

@{
    ViewData["Title"] = "Actor Details";
}

<div class="page-header">
    <h1>Actor Details</h1>
</div>

<div class="detail-card">
    <h4>@Model.Actor.Name</h4>
    <dl class="row">
        <dt class = "col-sm-2">
            Name
        </dt>
        <dd class = "col-sm-10">
            @Model.Actor.Name
        </dd>
        <dt class = "col-sm-2">
            Gender
        </dt>
        <dd class = "col-sm-10">
            @Model.Actor.Gender
        </dd>
        <dt class = "col-sm-2">
            Age
        </dt>
        <dd class = "col-sm-10">
            @Model.Actor.Age
        </dd>
        <dt class = "col-sm-2">
            IMDB URL
        </dt>
        <dd class = "col-sm-10">
            <a href="@Model.Actor.ImdbUrl" target="_blank">@Model.Actor.ImdbUrl</a>
        </dd>
        <dt class = "col-sm-2">
            Photo
        </dt>
        <dd class = "col-sm-10">
            @if (!string.IsNullOrEmpty(Model.Actor.PhotoUrl))
            {
                <img src="@Model.Actor.PhotoUrl" alt="@Model.Actor.Name" class="actor-photo" />
            }
            else
            {
                <span class="text-muted">No photo available</span>
            }
        </dd>
    </dl>
</div>

<hr />

<!-- Movies this Actor is in Section -->
@if (Model.Actor.MovieActors != null && Model.Actor.MovieActors.Any())
{
    <div class="detail-card">
        <h4>Movies featuring @Model.Actor.Name</h4>
        <table class="table table-hover cross-link-table">
            <thead>
                <tr>
                    <th>Movie Title</th>
                    <th>Character Name</th>
                    <th>Release Year</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ma in Model.Actor.MovieActors)
                {
                    <tr>
                        <td>@ma.Movie.Title</td>
                        <td>@ma.CharacterName</td>
                        <td>@ma.Movie.ReleaseYear</td>
                        <td>
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@ma.MovieId" class="btn btn-sm btn-info">View Movie</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="sentiment-section">
    <h3>@Model.OverallSentimentData.GetDisplayString()</h3>

    @if (Model.CommentSentiments.Any())
    {
        <div class="comments-card">
            <table id="commentsTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Comment</th>
                        <th>Sentiment</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.CommentSentiments)
                    {
                        <tr>
                            <td>@row.CommentText</td>
                            <td>@row.SentimentDisplay</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No Reddit comments found for this actor.</p>
    }
</div>

<div class="btn-group-actions">
    <a asp-action="Edit" asp-route-id="@Model.Actor.ActorId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#commentsTable').DataTable({
                "pageLength": 10,
                "order": [[1, "desc"]],
                "language": {
                    "search": "Search comments:"
                }
            });
        });
    </script>
}
