@model cprestegard_sp2026_assignment3.ViewModels.MovieDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <h1>Movie Details</h1>
</div>

<div class="detail-card">
    <h4>@Model.Movie.Title</h4>
    <dl class="row">
        <dt class = "col-sm-2">
            Title
        </dt>
        <dd class = "col-sm-10">
            @Model.Movie.Title
        </dd>
        <dt class = "col-sm-2">
            IMDB URL
        </dt>
        <dd class = "col-sm-10">
            <a href="@Model.Movie.ImdbUrl" target="_blank">@Model.Movie.ImdbUrl</a>
        </dd>
        <dt class = "col-sm-2">
            Genre
        </dt>
        <dd class = "col-sm-10">
            @Model.Movie.Genre
        </dd>
        <dt class = "col-sm-2">
            Release Year
        </dt>
        <dd class = "col-sm-10">
            @Model.Movie.ReleaseYear
        </dd>
        <dt class = "col-sm-2">
            Poster
        </dt>
        <dd class = "col-sm-10">
            @if (!string.IsNullOrEmpty(Model.Movie.PosterUrl))
            {
                <img src="@Model.Movie.PosterUrl" alt="@Model.Movie.Title" class="movie-poster" />
            }
            else
            {
                <span class="text-muted">No poster available</span>
            }
        </dd>
    </dl>
</div>

<hr />

<!-- Actors in this Movie Section -->
@if (Model.Movie.MovieActors != null && Model.Movie.MovieActors.Any())
{
    <div class="detail-card">
        <h4>Actors in this Movie</h4>
        <table class="table table-hover cross-link-table">
            <thead>
                <tr>
                    <th>Actor Name</th>
                    <th>Character Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ma in Model.Movie.MovieActors)
                {
                    <tr>
                        <td>@ma.Actor.Name</td>
                        <td>@ma.CharacterName</td>
                        <td>
                            <a asp-controller="Actors" asp-action="Details" asp-route-id="@ma.ActorId" class="btn btn-sm btn-info">View Actor</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="sentiment-section">
    <h3>@Model.OverallSentimentData.GetDisplayString()</h3>

    @if (Model.CommentSentiments.Any())
    {
        <div class="comments-card">
            <table id="commentsTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Comment</th>
                        <th>Sentiment</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.CommentSentiments)
                    {
                        <tr>
                            <td>@row.CommentText</td>
                            <td>@row.SentimentDisplay</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No Reddit comments found for this movie.</p>
    }
</div>

<div class="btn-group-actions">
    <a asp-action="Edit" asp-route-id="@Model.Movie.MovieId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#commentsTable').DataTable({
                "pageLength": 10,
                "order": [[1, "desc"]],
                "language": {
                    "search": "Search comments:"
                }
            });
        });
    </script>
}
