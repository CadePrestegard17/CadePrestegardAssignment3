@model IEnumerable<cprestegard_sp2026_assignment3.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="page-header">
    <h1>Movies</h1>
</div>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table id="moviesTable" class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Poster</th>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReleaseYear)
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(item.PosterUrl))
                {
                    <img src="@item.PosterUrl" alt="@item.Title" style="width: 50px; height: 75px; object-fit: cover; border-radius: 4px;" />
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Genre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseYear)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MovieId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MovieId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MovieId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#moviesTable').DataTable({
                "pageLength": 10,
                "order": [[0, "asc"]],
                "language": {
                    "search": "Search movies:"
                }
            });
        });
    </script>
}
